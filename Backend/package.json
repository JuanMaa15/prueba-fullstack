{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "node --env-file=.env node_modules/prisma/build/index.js generate",
    "db:migrate": "node --env-file=.env node_modules/prisma/build/index.js migrate dev",
    "db:seed": "tsx --env-file=.env src/infrastructure/prisma/seed.ts",
    "prepare": "cd .. && husky Backend/.husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "prisma": "^7.8.0",
    "read-excel-file": "^9.3.1",
    "tsx": "^4.23.1",
    "typescript": "<6.1",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
